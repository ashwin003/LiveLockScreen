<schemalist>
    <schema id="org.gnome.shell.extensions.live-lockscreen" path="/org/gnome/shell/extensions/live-lockscreen/">
        <key name="background-video-path" type="s">
            <default>""</default>
            <summary>Path to background video</summary>
        </key>
        <key name="background-video-blur-radius" type="i">
            <range min="0" max="100" />
            <default>0</default>
            <summary>Background video blur radius</summary>
        </key>
        <key name="background-video-blur-brightness" type="d">
            <range min="0" max="1" />
            <default>0.65</default>
            <summary>Background video brightness</summary>
        </key>
        <key name="background-video-framerate" type="i">
            <range min="1" max="120" />
            <default>25</default>
            <summary>Background video framerate</summary>
        </key>
        <key name="background-video-looped" type="b">
            <default>true</default>
            <summary>Is background video looped</summary>
        </key>
        <key name="background-audio-volume" type="i">
            <range min="0" max="100" />
            <default>0</default>
            <summary>Background audio volume</summary>
        </key>
        <key name="background-fade-in-duration" type="i">
            <range min="0" max="600000" />
            <default>500</default>
            <summary>Background fade-in animation duration</summary>
        </key>
        
        <key name="debug-skip-frame" type="b">
            <default>false</default>
            <summary>Whether to skip the first frame of video or not</summary>
            <description>Sometimes the very first frame of the video might be completely green, so there is an option to skip it</description>
        </key>
        <key name="debug-use-unsafe-pipeline" type="b">
            <default>false</default>
            <summary>Whether to use the old unsafe pipeline in case you experience issues or artifacts. However it cause shell crashes</summary>
        </key>
    </schema>
</schemalist>